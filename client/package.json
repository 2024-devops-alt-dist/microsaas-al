    },
    "devDependencies": {
        "@eslint/js": "^9.33.0",
        "@playwright/test": "^1.58.2",
        "@tailwindcss/vite": "^4.1.14",
        "@types/react": "^19.1.10",
        "@types/react-dom": "^19.1.7",
        "@vitejs/plugin-react": "^5.0.0",
        "tailwindcss": "^4.1.14",
        "typescript": "^5.9.3",
